async function doLogin() {
  const u = document.getElementById('login-user').value.trim();
  const p = document.getElementById('login-pass').value;
  const btn = document.getElementById('login-btn');
  const errBanner = document.getElementById('login-err-banner');

  if (!u || !p) { errBanner.classList.add('show'); return; }

  errBanner.classList.remove('show');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Signing in…';

  try {
    // ── Authenticate against the "users" sheet ──
    const res = await apiGet({ action: 'login', username: u, password: p });

    if (res && res.ok) {
      state.user = {
        username: res.username,
        role:     res.role,
        name:     res.name,
        initial:  res.initial,
        pass:     p, // keep locally for change-password check
      };
      document.getElementById('login-screen').style.display = 'none';
      document.getElementById('app').style.display = 'block';
      await initApp();
    } else {
      errBanner.classList.add('show');
    }
  } catch (err) {
    // Fallback: if GSheet is unreachable, use local USERS object
    console.warn('GSheet login failed, falling back to local auth:', err);
    if (USERS[u] && USERS[u].pass === p) {
      state.user = { ...USERS[u], username: u };
      document.getElementById('login-screen').style.display = 'none';
      document.getElementById('app').style.display = 'block';
      await initApp();
    } else {
      errBanner.classList.add('show');
    }
  }

  btn.disabled = false;
  btn.innerHTML = 'Sign In';
}
document.addEventListener('keydown', e => {

  } catch (e) {
    console.error('loadConcerns failed', e);
  }
  renderConcernsAdmin();
  renderCouncilConcerns();
  renderMyConcerns();
  updateStats();
}

async function submitConcern() {
  const body = document.getElementById('c-body').value.trim();
  if (!body) { toast('Please describe your concern.'); return; }

  const btn = document.getElementById('concern-btn');
  btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Submitting…';

  const anon = document.getElementById('c-anon').value === 'yes';
  const name = anon ? 'Anonymous' : (document.getElementById('c-name').value.trim() || state.user.name);
  const entry = {
    action: 'addConcern',
    date: new Date().toLocaleDateString('en-PH'),
    name, cat: document.getElementById('c-cat').value,
    urgency: document.getElementById('c-urgency').value,
    body, status: 'Open',
    user: state.user.username,
  };

  try {
    const res = await apiPost(entry);
    if (res && res.ok) {
      toast('✅ Concern submitted to Sheets!');
      if (res.id) entry.id = res.id;
    } else {
      toast('⚠ Sheets sync issue — saved locally.', true);
    }
  } catch (e) {
    toast('⚠ Could not reach Sheets — saved locally.', true);
  }

  // Optimistic
  entry.id = entry.id || Date.now();
  state.concerns.push(entry);
  document.getElementById('c-body').value = '';
  document.getElementById('c-name').value = '';
  renderConcernsAdmin(); renderCouncilConcerns(); renderMyConcerns(); updateStats();
  btn.disabled = false; btn.innerHTML = 'Submit Concern';
}

async function resolveConcern(id) {
  const idx = state.concerns.findIndex(c => String(c.id) === String(id));
  if (idx === -1) return;
  state.concerns[idx].status = 'Resolved';
  renderConcernsAdmin(); renderCouncilConcerns(); renderMyConcerns(); updateStats();

  try {
    await apiPost({ action: 'resolveConcern', id });
    toast('✅ Concern marked as resolved in Sheets.');
  } catch (e) {
    toast('⚠ Local update done — Sheets sync failed.', true);
  }
}

function renderMyConcerns() {
  const tbody = document.getElementById('my-concerns-body');
  const mine = state.concerns.filter(c => c.user === state.user?.username);
  if (!mine.length) { tbody.innerHTML = '<tr><td colspan="4" class="empty-state">No submissions yet.</td></tr>'; return; }
  tbody.innerHTML = mine.map(c => `
    <tr>
      <td>${c.date}</td><td>${c.cat}</td>
      <td><span class="badge-pill ${c.status==='Open'?'pill-yellow':'pill-green'}">${c.status}</span></td>
      <td style="font-size:13px;color:var(--gray-600);">${(c.body||'').substring(0,50)}…</td>
    </tr>`).join('');
}

function renderConcernsAdmin() {
  const tbody = document.getElementById('admin-concerns-body');
  if (!state.concerns.length) { tbody.innerHTML = '<tr><td colspan="6" class="empty-state">No concerns yet.</td></tr>'; return; }
  tbody.innerHTML = state.concerns.map(c => {
    const urgCls = c.urgency==='High'?'pill-red':c.urgency==='Medium'?'pill-yellow':'pill-green';
    const resolveBtn = c.status==='Open' ? `<button class="btn btn-sm btn-secondary" style="margin-left:4px" onclick="resolveConcern('${c.id}')">Resolve</button>` : '';
    return `<tr>
      <td>${c.date}</td><td>${c.name}</td><td>${c.cat}</td>
      <td><span class="badge-pill ${urgCls}">${c.urgency}</span></td>
      <td><span class="badge-pill ${c.status==='Open'?'pill-yellow':'pill-green'}">${c.status}</span></td>
      <td>
        <button class="btn btn-sm btn-primary" onclick="viewConcern('${c.id}')">View</button>
        ${resolveBtn}
      </td>
    </tr>`;
  }).join('');
}

function renderCouncilConcerns() {
  const tbody = document.getElementById('council-concerns-body');
  if (!state.concerns.length) { tbody.innerHTML = '<tr><td colspan="5" class="empty-state">No concerns yet.</td></tr>'; return; }
  tbody.innerHTML = state.concerns.map(c => {
    const resolveBtn = c.status==='Open' ? `<button class="btn btn-sm btn-secondary" style="margin-left:4px" onclick="resolveConcern('${c.id}')">Resolve</button>` : '';
    return `<tr>
      <td>${c.date}</td><td>${c.name}</td><td>${c.cat}</td>
      <td><span class="badge-pill ${c.status==='Open'?'pill-yellow':'pill-green'}">${c.status}</span></td>
      <td>
        <button class="btn btn-sm btn-primary" onclick="viewConcern('${c.id}')">View</button>
        ${resolveBtn}
      </td>
    </tr>`;
  }).join('');
}

function viewConcern(id) {
  const c = state.concerns.find(x => String(x.id) === String(id));
  if (!c) return;
  document.getElementById('modal-title').textContent = `${c.cat} Concern`;
  document.getElementById('modal-sub').textContent = `By ${c.name} · ${c.date}`;
  document.getElementById('modal-body').innerHTML = `
    <p style="font-size:14px;line-height:1.7;color:var(--gray-800);">${c.body}</p>
    <p style="margin-top:12px;font-size:13px;color:var(--gray-400);">Urgency: ${c.urgency} · Status: ${c.status}</p>`;
  document.getElementById('modal').classList.add('open');
}

/* ══════════════════════════════════════════
   GSHEET — EVALUATIONS
   ══════════════════════════════════════════ */
async function loadEvals() {
  try {
    const data = await apiGet({ action: 'getEvals' });
    // Expected: { evals: [{date, event, rating, comment, submittedBy}] }
    if (data && Array.isArray(data.evals)) {
      state.evals = data.evals;
    }
  } catch (e) {
    console.error('loadEvals failed', e);
  }
  renderEvalsAdmin();
  updateStats();
}

let starVal = 0;
function setStar(v) {
  starVal = v;
  document.querySelectorAll('.star').forEach(s => s.classList.toggle('lit', +s.dataset.v <= v));
}

async function submitEval() {
  if (!starVal) { toast('Please select a star rating.'); return; }
  const btn = document.getElementById('eval-btn');
  btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Submitting…';

  const entry = {
    action: 'addEval',
    date: new Date().toLocaleDateString('en-PH'),
    event: document.getElementById('ev-name').value,
    rating: starVal,
    comment: document.getElementById('ev-comment').value.trim(),
    submittedBy: state.user.name,
    user: state.user.username,
  };

  try {
    const res = await apiPost(entry);
    if (res && res.ok) {
      toast('✅ Evaluation submitted to Sheets!');
    } else {
      toast('⚠ Sheets sync issue — saved locally.', true);
    }
  } catch (e) {
    toast('⚠ Could not reach Sheets — saved locally.', true);
  }

  state.evals.push(entry);
  setStar(0); document.getElementById('ev-comment').value = '';
  renderEvalsAdmin(); updateStats();
  btn.disabled = false; btn.innerHTML = 'Submit Evaluation';
}

function renderEvalsAdmin() {
  const tbody = document.getElementById('admin-evals-body');
  if (!state.evals.length) { tbody.innerHTML = '<tr><td colspan="5" class="empty-state">No evaluations yet.</td></tr>'; return; }
  tbody.innerHTML = state.evals.map(e => `
    <tr>
      <td>${e.date}</td><td>${e.event}</td>
      <td>${'★'.repeat(e.rating)}${'☆'.repeat(5-e.rating)}</td>
      <td style="font-size:13px;">${e.comment||'—'}</td>
      <td style="font-size:13px;">${e.submittedBy||'—'}</td>
    </tr>`).join('');
}

/* ══════════════════════════════════════════
   REFRESH HELPERS (admin/council)
   ══════════════════════════════════════════ */
async function refreshAdmin() {
  toast('🔄 Refreshing from Sheets…');
  await Promise.all([loadPosts(), loadConcerns(), loadEvals()]);
  toast('✅ Data refreshed!');
}
async function refreshCouncil() {
  toast('🔄 Refreshing from Sheets…');
  await Promise.all([loadConcerns(), loadEvals()]);
  toast('✅ Data refreshed!');
}

/* ══════════════════════════════════════════
   CHAT (local + simulated adviser reply)
   ══════════════════════════════════════════ */
const ADVISER_REPLIES = [
  "Thank you for reaching out! I'll look into this.",
  "Noted! I'll get back to you soon.",
  "Great question! Let me check and reply.",
  "Thanks for your message. We'll address this right away.",
];
function initChat() { renderChat(); }
function renderChat() {
  const win = document.getElementById('chat-window');
  win.innerHTML = '';
  state.chats.default.forEach(m => {
    const b = document.createElement('div');
    b.className = 'chat-bubble ' + m.from;
    b.innerHTML = `${m.text}<div class="chat-meta">${m.time}</div>`;
    win.appendChild(b);
  });
  win.scrollTop = win.scrollHeight;
}
function sendChat() {
  const inp = document.getElementById('chat-input');
  const txt = inp.value.trim(); if (!txt) return;
  const now = new Date().toLocaleTimeString('en-PH',{hour:'2-digit',minute:'2-digit'});
  state.chats.default.push({ from:'sent', text:txt, time:now });
  inp.value = ''; renderChat();
  setTimeout(() => {
    state.chats.default.push({ from:'recv', text:ADVISER_REPLIES[Math.floor(Math.random()*ADVISER_REPLIES.length)], time:new Date().toLocaleTimeString('en-PH',{hour:'2-digit',minute:'2-digit'}) });
    renderChat();
  }, 1200);
}

/* ══════════════════════════════════════════
   MEMBERS & RESOURCES
   ══════════════════════════════════════════ */
function renderMembers() {
  document.getElementById('member-grid').innerHTML = MEMBERS.map(m => `
    <div class="member-card">
      <div class="member-avatar">${m.i}</div>
      <div class="member-name">${m.name}</div>
      <div class="member-role">${m.role}</div>
    </div>`).join('');
}
function renderResources() {
  document.getElementById('resource-list').innerHTML = RESOURCES.map(r => `
    <div class="resource-item">
      <div class="resource-icon">${r.icon}</div>
      <div class="resource-info">
        <div class="res-name">${r.name}</div>
        <div class="res-desc">${r.desc}</div>
      </div>
      <button class="btn btn-secondary btn-sm res-dl" onclick="toast('Download started!')">⬇ ${r.ext}</button>
    </div>`).join('');
}

/* ══════════════════════════════════════════
   STATS
   ══════════════════════════════════════════ */
function updateStats() {
  const open = state.concerns.filter(c=>c.status==='Open').length;
  document.getElementById('stat-concerns').textContent = state.concerns.length;
  document.getElementById('stat-evals').textContent    = state.evals.length;
  document.getElementById('stat-posts').textContent    = state.posts.length;
  const csc = document.getElementById('cs-stat-concerns');
  const cse = document.getElementById('cs-stat-evals');
  if (csc) csc.textContent = open;
  if (cse) cse.textContent = state.evals.length;
}

/* ══════════════════════════════════════════
   CHANGE PASSWORD
   ══════════════════════════════════════════ */
function changePassword() {
  const cur = document.getElementById('pw-current').value;
  const nw  = document.getElementById('pw-new').value;
  const cf  = document.getElementById('pw-confirm').value;
  if (cur !== state.user.pass) { toast('⚠ Current password is incorrect.', true); return; }
  if (nw.length < 6) { toast('⚠ New password must be at least 6 characters.', true); return; }
  if (nw !== cf) { toast('⚠ Passwords do not match.', true); return; }
  state.user.pass = nw; if (USERS[state.user.username]) USERS[state.user.username].pass = nw;
  document.getElementById('pw-current').value='';
  document.getElementById('pw-new').value='';
  document.getElementById('pw-confirm').value='';
  toast('✅ Password updated!');
}

/* ══════════════════════════════════════════
   ADMIN TABS
   ══════════════════════════════════════════ */
function switchTab(id, btn) {
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
  if (btn) btn.classList.add('active');
}

/* ══════════════════════════════════════════
   MODAL
   ══════════════════════════════════════════ */
function closeModal() { document.getElementById('modal').classList.remove('open'); }
document.getElementById('modal').addEventListener('click', e => { if (e.target===document.getElementById('modal')) closeModal(); });

/* ══════════════════════════════════════════
   TOAST
   ══════════════════════════════════════════ */
let toastTimer;
function toast(msg, isError=false) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.toggle('error', isError);
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 3000);
}
</script>

async function publishPost() {
  const text = document.getElementById('post-text').value.trim();
  const caption = document.getElementById('caption-input') ? document.getElementById('caption-input').value.trim() : '';
  if (!text && state.pendingImgs.length === 0) { toast('Please write something or attach an image.'); return; }

  const btn = document.getElementById('post-btn');
  btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Posting…';

  const u = state.user;
  const postData = {
    action: 'addPost',
    author: u.name,
    initial: u.initial,
    time: new Date().toLocaleString('en-PH', { month:'short', day:'numeric', year:'numeric', hour:'2-digit', minute:'2-digit' }),
    text,
    caption,
    imgs: state.pendingImgs, // base64 strings — note: large images may exceed GAS limits
    submittedBy: u.username,
  };

  try {
    const res = await apiPost(postData);
    if (res && res.ok) {
      toast('✅ Announcement posted to Sheets!');
    } else {
      toast('⚠ Sheets sync issue — post saved locally.', true);
    }
  } catch (e) {
    toast('⚠ Could not reach Sheets — saved locally.', true);
  }

  // Optimistic local update
  state.posts.unshift({ id: Date.now(), author: u.name, initial: u.initial, time:'Just now', text, imgs:[...state.pendingImgs], caption });
  document.getElementById('post-text').value = '';
  document.getElementById('img-previews').innerHTML = '';
  document.getElementById('post-imgs').value = '';
  state.pendingImgs = [];
  renderPosts(); updateStats();
  btn.disabled = false; btn.innerHTML = '🚀 Post';
}

function previewImgs(input) {
  const wrap = document.getElementById('img-previews');
  wrap.innerHTML = '';
  state.pendingImgs = [];
  Array.from(input.files).forEach((file, i) => {
    const reader = new FileReader();
    reader.onload = e => {
      state.pendingImgs[i] = e.target.result;
      const item = document.createElement('div');
      item.className = 'img-preview-item';
      item.innerHTML = `<img src="${e.target.result}"><button class="remove-img" onclick="removeImgAt(${i})">✕</button>`;
      if (i === 0) {
        const cap = document.createElement('input');
        cap.className = 'caption-input'; cap.id = 'caption-input'; cap.placeholder = 'Add a caption…';
        wrap.appendChild(item); wrap.appendChild(cap);
      } else { wrap.insertBefore(item, wrap.lastChild); }
    };
    reader.readAsDataURL(file);
  });
}
function removeImgAt(i) { state.pendingImgs.splice(i,1); document.getElementById('img-previews').innerHTML=''; state.pendingImgs=[]; }

function renderPosts() {
  const feed = document.getElementById('posts-feed');
  feed.innerHTML = '';
  if (!state.posts.length) { feed.innerHTML = '<div class="empty-state">No announcements yet.</div>'; return; }
  state.posts.forEach(p => {
    const imgs = p.imgs || [];
    const cls = imgs.length===1?'one':imgs.length===2?'two':imgs.length>2?'many':'';
    const imgsHTML = imgs.length ? `<div class="post-images ${cls}">${imgs.map(src=>`<img src="${src}" loading="lazy">`).join('')}</div>` : '';
    const capHTML  = p.caption ? `<div class="post-caption">📷 ${p.caption}</div>` : '';
    feed.innerHTML += `
      <div class="post-card">
        <div class="post-header">
          <div class="post-avatar">${p.initial||'?'}</div>
          <div class="post-meta">
            <div class="post-author">${p.author}</div>
            <div class="post-time">${p.time}</div>
          </div>
        </div>
        <div class="post-body">${p.text}</div>
        ${imgsHTML}${capHTML}
        <div class="post-footer"><span style="font-size:13px;color:var(--gray-400);">👍 Like &nbsp; 💬 Comment</span></div>
      </div>`;
  });
}

